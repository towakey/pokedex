{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/towakey/pokedex/schemas/translate_waza.schema.json",
  "title": "Translate Waza",
  "description": "わざ翻訳データ (translate/waza.json)。日本語わざ名をキーとし、各言語の翻訳を格納。",
  "type": "object",
  "required": ["update", "translate"],
  "properties": {
    "update": {
      "type": "string",
      "description": "データ更新日"
    },
    "translate": {
      "type": "array",
      "description": "わざ翻訳データの配列。各要素はわざ名(日本語)をキーとするオブジェクト。",
      "items": {
        "type": "object",
        "additionalProperties": {
          "$ref": "#/definitions/WazaTranslation"
        }
      }
    }
  },
  "definitions": {
    "WazaTranslation": {
      "type": "object",
      "description": "1つのわざの多言語翻訳",
      "properties": {
        "eng": { "type": "string", "description": "英語" },
        "fra": { "type": "string", "description": "フランス語" },
        "ger": { "type": "string", "description": "ドイツ語" },
        "ita": { "type": "string", "description": "イタリア語" },
        "spa": { "type": "string", "description": "スペイン語" },
        "kor": { "type": "string", "description": "韓国語" },
        "chs": { "type": "string", "description": "簡体字中国語" },
        "cht": { "type": "string", "description": "繁体字中国語" }
      },
      "additionalProperties": false
    }
  }
}
